# Deny all direct HTTP access to this folder.
# Contains the SQLite database and migration script — never serve over the web.
<IfModule mod_authz_core.c>
    # Apache 2.4+
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    # Apache 2.2
    Order allow,deny
    Deny from all
</IfModule>
