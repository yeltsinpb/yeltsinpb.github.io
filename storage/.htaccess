# Deny all direct HTTP access to this folder.
# Holds uploads, cv.json and fonts. Files are served through index.php, never directly.
<IfModule mod_authz_core.c>
    # Apache 2.4+
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    # Apache 2.2
    Order allow,deny
    Deny from all
</IfModule>
